# OCR Service Configuration
PROJECT_NAME="OCR Service"
VERSION="1.0.0"
API_PREFIX="/api/v1"
API_V2_PREFIX="/api/v2"
API_V3_PREFIX="/api/v3"
OCR_SERVICE_PORT=8091

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro
# GEMINI_TEMPERATURE=0.2
# GEMINI_TOP_P=0.95
# GEMINI_TOP_K=40
# GEMINI_MAX_OUTPUT_TOKENS=8192

# Gemini thinking config
# Gemini 2.5: -1=dynamic, 0=disabled, >0=token budget
# GEMINI_THINKING_BUDGET=-1
# Gemini 3: minimal/low/medium/high
# GEMINI_THINKING_LEVEL=low

# OCR v2 pipeline
GEMINI_MAX_INLINE_IN_BYTES=104857600
GEMINI_MAX_CONCURRENT_EXTRACTIONS=3
OCR_EXTRACT_ALL_DOCUMENTS=true
OCR_HIGH_ACCURACY_DOCUMENT_CODES=claim_form
OCR_HIGH_ACCURACY_MODEL=gemini-2.5-pro

# Logging
LOG_LEVEL=INFO
LOG_FILE=ocr_service.log
