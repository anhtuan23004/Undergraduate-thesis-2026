# Agent Service Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME="Agent Service"
APP_VERSION="1.0.0"
DEBUG=false
HOST=0.0.0.0
PORT=8003
LOG_LEVEL=INFO

# =============================================================================
# GEMINI LLM
# =============================================================================
# Required: Your Gemini API key from https://aistudio.google.com/
GEMINI_API_KEY=

# Model settings
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_TOKENS=8192

# =============================================================================
# OPENAI LLM (Optional)
# =============================================================================
# Optional for Agent Service
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# =============================================================================
# MONGODB (State Persistence & Medicine Database)
# =============================================================================
MONGODB_URL=mongodb://admin:admin123@localhost:27017/claims?authSource=admin&directConnection=true
MONGODB_URL_AGENT=mongodb://admin:admin123@localhost:27017/claims?authSource=admin&directConnection=true
MONGODB_DB=claims
MEDICINE_DB=document_qa

# MongoDB Root Credentials (for Docker initialization)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin123
# =============================================================================
# SERVICE URLs
# =============================================================================
OCR_SERVICE_URL=http://localhost:8001

# =============================================================================
# PROCESSING
# =============================================================================
PROCESS_TIMEOUT=300
OCR_TIMEOUT=120
UPLOADS_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20

# =============================================================================
# DEBUGGING
# =============================================================================
# Pause at each stage for manual inspection
PAUSE_AT_EACH_STAGE=false

# Strict skill loading (fail on tool errors - for CI/testing)
STRICT_SKILL_LOADING=false

# =============================================================================
# AGENT REVIEW THRESHOLDS
# =============================================================================
# Amount threshold (VND) above which claims require agent review
AGENT_REVIEW_AMOUNT_THRESHOLD=5000000

# Confidence threshold below which claims require agent review
AGENT_REVIEW_CONFIDENCE_THRESHOLD=0.9

# =============================================================================
# OBSERVABILITY (Langfuse)
# =============================================================================
# Get keys from https://cloud.langfuse.com/
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_ENABLED=false

# =============================================================================
# CORS (Security)
# =============================================================================
# Comma-separated list of allowed origins, or leave empty for all (*)
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://example.com
ALLOWED_ORIGINS=

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Tavily Search API (for web fallback)
# Get key from https://tavily.com/
TAVILY_API_KEY=
