{
  "name": "check_exclusion",
  "description": "Check policy exclusions for diagnosis and procedure codes",
  "parameters": {
    "type": "object",
    "properties": {
      "diagnosis_codes": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "List of ICD-10 diagnosis codes"
      },
      "procedure_codes": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "List of procedure codes (optional)"
      },
      "policy_number": {
        "type": "string",
        "description": "Policy number to check exclusions against"
      }
    },
    "required": ["diagnosis_codes", "policy_number"]
  }
}
