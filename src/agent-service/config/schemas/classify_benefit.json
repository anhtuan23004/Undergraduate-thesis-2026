    "type": "object",
    "properties": {
      "diagnosis_codes": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "List of ICD-10 diagnosis codes"
      },
      "procedure_codes": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "List of procedure codes (optional)"
      }
    },
    "required": ["diagnosis_codes"]
  }
}
