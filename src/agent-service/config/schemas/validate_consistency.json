{
  "name": "validate_consistency",
  "description": "Validate consistency across claim data fields from multiple documents",
  "parameters": {
    "type": "object",
    "properties": {
      "patient_name": {
        "type": "string",
        "description": "Patient name from primary document"
      },
      "policy_number": {
        "type": "string",
        "description": "Insurance policy number"
      },
      "patient_id": {
        "type": "string",
        "description": "Patient ID or insurance number (optional)"
      },
      "claim_amount": {
        "type": "number",
        "description": "Total claim amount (optional)"
      },
      "service_date": {
        "type": "string",
        "description": "Date of service in ISO format YYYY-MM-DD (optional)"
      },
      "provider_name": {
        "type": "string",
        "description": "Healthcare provider name (optional)"
      },
      "documents": {
        "type": "array",
        "description": "List of extracted documents to cross-validate (optional)",
        "items": {
          "type": "object",
          "properties": {
            "doc_type": {
              "type": "string",
              "enum": [
                "invoice",
                "medical_record",
                "prescription",
                "receipt"
              ],
              "description": "Type of document"
            },
            "patient_name": {
              "type": "string"
            },
            "patient_id": {
              "type": "string"
            },
            "amount": {
              "type": "number"
            },
            "date": {
              "type": "string"
            },
            "provider": {
              "type": "string"
            }
          }
        }
      }
    },
    "required": [
      "patient_name",
      "policy_number"
    ]
  }
}