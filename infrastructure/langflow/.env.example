# Langflow Configuration

# Service Settings
LANGFLOW_PORT=7860
LANGFLOW_SECRET_KEY=changeme-secret-key-min-32-characters

# Auto-login (set to false for production)
LANGFLOW_AUTO_LOGIN=true
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=admin123

# Database
LANGFLOW_DB_PASSWORD=langflow

# API Keys for LLM Components
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Langfuse Integration
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Development
LANGFLOW_DEV_MODE=false
LANGFLOW_LOG_LEVEL=INFO
