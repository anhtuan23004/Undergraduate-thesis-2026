# Insurance Claims Processing System - Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================
# API Keys (REQUIRED)
# ============================================

# Google Gemini API (for OCR Service AND RAG Service embeddings)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# HuggingFace Token (for embedding models)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=

# OpenAI API (optional, backward compatibility in some components)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ============================================
# Database Configuration
# ============================================

# MongoDB (used by RAG and Agent services)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin123

# Milvus/MinIO (vector database storage)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ============================================
# Service Configuration
# ============================================

# RAG Service
MONGODB_URL=mongodb://claims_app:claims_password@localhost:27017/claims
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=insurance_kb_v2
MILVUS_DIM=3072                    # Gemini embedding dimension (3072, not 1536)
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Agent Service
MONGODB_URL_AGENT=mongodb://claims_app:claims_password@localhost:27017/claims

# Service Endpoints (for inter-service communication)
OCR_SERVICE_URL=http://localhost:8001
RAG_SERVICE_URL=http://localhost:8002
AGENT_SERVICE_URL=http://localhost:8003

# ============================================
# Optional Configuration
# ============================================

# Dify Configuration (if using workflow orchestration)
# DIFY_DB_PASSWORD=dify_password123
# DIFY_SECRET_KEY=your_dify_secret_key

Langfuse Configuration (Optional - for observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Langflow Configuration (Optional - for visual workflow design)
# LANGFLOW_PORT=7860
# LANGFLOW_SECRET_KEY=changeme-secret-key-min-32-characters
# LANGFLOW_AUTO_LOGIN=true
# LANGFLOW_SUPERUSER=admin
# LANGFLOW_SUPERUSER_PASSWORD=admin123
# LANGFLOW_DB_PASSWORD=langflow

# Development Settings
DEBUG=false
LOG_LEVEL=INFO
